local spawnZoneName = "z1"  --
local defaultAltitude = 500 -- in meters

-- 1. Utilitaire de récupération de zone sécurisé
local function getSafeZonePoint(zoneName)
    local zone = trigger.misc.getZone(zoneName)
    if zone then
        return zone.point
    else
        env.error("WITCHCRAFT ERROR: Zone '" .. tostring(zoneName) .. "' introuvable.")
        return nil
    end
end

-- 2. Méthode de spawn pour Groupes (Infanterie)
local function executeUnitSpawn()
    local pos = getSafeZonePoint(spawnZoneName)
    if not pos then return end

    local uniqueID = timer.getTime()
    local groupData = {
        ["name"] = "Grp_Soldier_" .. uniqueID,
        ["category"] = Group.Category.GROUND, -- API FIX: Utilisation de GROUND (non GROUND_UNIT)
        ["country"] = "USA",
        ["task"] = "Nothing",
        ["units"] = {
            [1] = {
                ["name"] = "Unit_Soldier_" .. uniqueID,
                ["type"] = "Soldier M4", --
                ["x"] = pos.x,
                ["y"] = pos.z,           -- Projection cartographique DCS (Y moteur = Z map)
                ["alt"] = defaultAltitude,
                ["alt_type"] = "BARO",
                ["heading"] = 0,
                ["skill"] = "Excellent",
            },
        },
    }

    -- Exécution protégée pour éviter le CTD en cas d'erreur API
    local status, err = pcall(function()
        return coalition.addGroup(country.id.USA, Group.Category.GROUND, groupData)
    end)

    if not status then
        env.error("WITCHCRAFT SPAWN ERROR: " .. tostring(err))
    end
    return 0
end

-- 3. Méthode de spawn pour StaticObject (Cargos)
local function executeStaticSpawn()
    --trigger.action.outText('executeStaticSpawn()', 5)
    local pos = getSafeZonePoint(spawnZoneName)
    if not pos then return end

    local uniqueID = timer.getTime()
    local staticData = {
        ["name"] = "Cargo_Box_" .. uniqueID,
        ["type"] = "iso_container", --
        ["x"] = pos.x,
        ["y"] = pos.z,
        ["alt"] = defaultAltitude,
        ["alt_type"] = "BARO",
        ["heading"] = 0,
        ["category"] = "Cargos",
        ["canCargo"] = true,
        ["mass"] = 500,
    }

    local status, err = pcall(function()
        return coalition.addStaticObject(country.id.USA, staticData)
    end)

    if not status then
        env.error("WITCHCRAFT STATIC ERROR: " .. tostring(err))
    end
    return 0
end

local function ot(msg, duration)
    trigger.action.outText(msg, duration)
end
-- 4. Handler d'événements sécurisé (Anti-Crash)
if app.ParachuteAnalysisHandler == nil then
    app.ParachuteAnalysisHandler = {}
    function app.ParachuteAnalysisHandler:onEvent(event)
        -- Protection contre les événements sans initiateur ou objets détruits
        if not event or not event.id or not event.initiator then return end

        -- Vérification de l'existence de l'objet avant appel de méthode [cite: 2026-02-02]
        if not Object.isExist(event.initiator) then return end

        local initiatorName = "Unknown"
        local status, res = pcall(function() return event.initiator:getName() end)
        if status then initiatorName = res end

        -- Filtrage des événements pour éviter la saturation du log
        local trackedEvents = { [15] = "BIRTH", [8] = "DEAD", [30] = "CARGO_UNHOOKED" }

        if trackedEvents[event.id] then
            local output = string.format(
                "EVENT: %s | INITIATOR: %s | TIME: %.2f",
                trackedEvents[event.id],
                initiatorName,
                timer.getTime()
            )
            --trigger.action.outText(output, 5)
            ot(output, 5)
            env.info("PARA_LOG: " .. output)
        end
    end
end

-- 5. Initialisation
if app.eventActive == false then
    trigger.action.outText("world.addEventHandler(app.ParachuteAnalysisHandler)", 5)
    world.addEventHandler(app.ParachuteAnalysisHandler)
    app.eventActive = true
end

