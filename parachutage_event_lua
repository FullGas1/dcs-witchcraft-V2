local spawnZoneName = "z1"
local defaultAltitude = 500

-- 1. Utilitaire de récupération de zone
local function getSafeZonePoint(zoneName)
    env.info("DEBUG: Appel getSafeZonePoint(zoneName: " .. tostring(zoneName) .. ")")

    local zone = trigger.misc.getZone(zoneName)
    if zone then
        env.info("DEBUG: Zone '" .. zoneName .. "' trouvée aux coordonnées x:" .. zone.point.x .. " z:" .. zone.point.z)
        return zone.point
    else
        local errorMsg = "ERREUR FATALE : Zone '" .. tostring(zoneName) .. "' introuvable dans la mission."
        trigger.action.outText(errorMsg, 15)
        env.error(errorMsg)
        return nil
    end
end

-- 2. Méthode de spawn pour Groupes (Unités)
local function executeUnitSpawn()
    env.info("DEBUG: Appel executeUnitSpawn()")
    trigger.action.outText("DEBUG: Exécution executeUnitSpawn...", 2)

    local pos = getSafeZonePoint(spawnZoneName)
    if not pos then return end

    local groupData = {
        ["name"] = "Grp_Soldier_" .. math.random(1, 9999),
        ["category"] = Group.Category.GROUND_UNIT,
        ["country"] = "USA",
        ["task"] = "Nothing",
        ["units"] = {
            [1] = {
                ["name"] = "Unit_Soldier_" .. math.random(1, 9999),
                ["type"] = "Soldier M4",
                ["x"] = pos.x,
                ["y"] = pos.z,
                ["alt"] = defaultAltitude,
                ["alt_type"] = "BARO",
                ["heading"] = 0,
                ["skill"] = "Excellent",
            },
        },
    }
    coalition.addGroup(country.id.USA, Group.Category.GROUND_UNIT, groupData)
    env.info("DEBUG: executeUnitSpawn terminé avec succès.")
end

-- 3. Méthode de spawn pour StaticObject (Cargos)
local function executeStaticSpawn()
    env.info("DEBUG: Appel executeStaticSpawn()")
    trigger.action.outText("DEBUG: Exécution executeStaticSpawn...", 2)

    local pos = getSafeZonePoint(spawnZoneName)
    if not pos then return end

    local staticData = {
        ["name"] = "Cargo_Box_" .. math.random(1, 9999),
        ["type"] = "iso_container_cargo",
        ["x"] = pos.x,
        ["y"] = pos.z,
        ["alt"] = defaultAltitude,
        ["alt_type"] = "BARO",
        ["heading"] = 0,
        ["category"] = "Cargos",
        ["canCargo"] = true,
        ["mass"] = 500,
    }
    coalition.addStaticObject(country.id.USA, staticData)
    env.info("DEBUG: executeStaticSpawn terminé avec succès.")
end

-- 4. Handler d'événements
local ParachuteAnalysisHandler = {}
function ParachuteAnalysisHandler:onEvent(event)
    -- Trace d'entrée d'événement (silencieuse en log uniquement pour éviter le flood visuel)
    env.info("DEBUG: Event détecté ID: " .. tostring(event.id))

    local eventName = "UNDEFINED"
    for name, id in pairs(world.event) do
        if id == event.id then
            eventName = name
            break
        end
    end

    local initiatorName = "Environment"
    if event.initiator and event.initiator.getName then
        local status, res = pcall(function() return event.initiator:getName() end)
        if status then initiatorName = res end
    end

    local output = string.format(
        "EVENT: %s (ID: %s)\nINITIATOR: %s\nTIME: %.3f",
        eventName,
        tostring(event.id),
        initiatorName,
        timer.getTime()
    )

    trigger.action.outText(output, 7)
    env.info("PARA_LOG: " .. output)
end

-- 5. Initialisation et Séquencement
env.info("DEBUG: Initialisation du EventHandler")
world.addEventHandler(ParachuteAnalysisHandler)

-- EXEMPLE 1 : SOLDAT M4
trigger.action.outText("--- DÉBUT EXEMPLE 1 : SPAWN SOLDAT ---", 5)
env.info("STATUT: Début de l'Exemple 1")

executeUnitSpawn()

env.info("STATUT: Fin de l'Exemple 1 (Spawn lancé)")
trigger.action.outText("--- FIN EXEMPLE 1 ---", 2)


-- EXEMPLE 2 : CAISSE (T+10s)
timer.scheduleFunction(function()
    trigger.action.outText("--- DÉBUT EXEMPLE 2 : SPAWN CAISSE (TIMER) ---", 5)
    env.info("STATUT: Début de l'Exemple 2 via Timer")

    executeStaticSpawn()

    env.info("STATUT: Fin de l'Exemple 2")
    trigger.action.outText("--- FIN EXEMPLE 2 ---", 2)
end, nil, timer.getTime() + 10)
